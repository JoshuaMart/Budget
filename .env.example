# Origin URL — used by SvelteKit (CSRF) and better-auth (cookie domain).
# In dev: http://localhost:5173 — in prod: https://your.domain
ORIGIN=http://localhost:5173

# Path to the SQLite database file (relative to project root).
# Created automatically on first run; never commit the *.db file.
DATABASE_URL=./data/budget.db

# Secret used by better-auth to sign session cookies.
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-32-bytes-of-randomness
